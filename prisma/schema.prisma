// prisma/schema.prisma
//
// Database schema for OMS Hook Connector.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shopify authentication sessions.
// Shopify's Prisma session-storage package depends on this model.
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

// Stores one OMS connection for each Shopify store.
model OmsConnection {
  id              String  @id @default(cuid())
  shop            String  @unique
  endpoint        String
  encryptedApiKey String
  isEnabled       Boolean @default(true)

  lastTestedAt      DateTime?
  lastTestSucceeded Boolean?
  lastTestMessage   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isEnabled])
}

// Records incoming Shopify webhook deliveries.
model WebhookEvent {
  id               String  @id @default(cuid())
  shop             String
  shopifyWebhookId String  @unique
  topic            String
  shopifyOrderId   String?
  status           String  @default("RECEIVED")
  errorMessage     String?

  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  orderPushJob OrderPushJob?

  @@index([shop, receivedAt])
  @@index([shop, status])
  @@index([shopifyOrderId])
}

// Stores a durable job for sending an order to the OMS.
model OrderPushJob {
  id             String       @id @default(cuid())
  shop           String
  webhookEventId String       @unique
  webhookEvent   WebhookEvent @relation(fields: [webhookEventId], references: [id], onDelete: Cascade)

  externalOrderId String
  invoiceId       String?

  // Kept temporarily for compatibility with old records.
  // New orders do not write a plaintext customer name here.
  customerName String?

  // Complete OMS order encrypted using AES-256-GCM.
  // Removed after successful delivery or retention expiry.
  encryptedPayload String?

  // Failed or pending personal data expires after seven days.
  personalDataExpiresAt DateTime?

  // Time when the protected order payload was removed.
  payloadPurgedAt DateTime?

  status        String   @default("PENDING")
  attempts      Int      @default(0)
  maxAttempts   Int      @default(7)
  nextAttemptAt DateTime @default(now())
  lastError     String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  logs OrderPushLog[]

  @@index([shop, createdAt])
  @@index([shop, status])
  @@index([status, nextAttemptAt])
  @@index([externalOrderId])
  @@index([personalDataExpiresAt])
}

// Stores delivery attempts without names, phones or addresses.
model OrderPushLog {
  id    String       @id @default(cuid())
  shop  String
  jobId String
  job   OrderPushJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  externalOrderId String
  invoiceId       String?
  status          String
  attemptNumber   Int
  httpStatus      Int?
  durationMs      Int?
  errorMessage    String?
  responseSummary String?

  createdAt DateTime @default(now())

  @@index([shop, createdAt])
  @@index([shop, status])
  @@index([jobId, attemptNumber])
  @@index([externalOrderId])
}

// Tracks a Shopify customers/data_request request.
//
// All customer identifiers, requested Shopify order IDs and report
// contents will be stored only inside encryptedReport.
model PrivacyDataRequest {
  id               String @id @default(cuid())
  shop             String
  shopifyWebhookId String @unique

  status              String @default("READY")
  requestedOrderCount Int    @default(0)
  matchedOrderCount   Int    @default(0)

  // Encrypted JSON report for the authenticated merchant.
  encryptedReport String?

  // The encrypted report is available for 30 days.
  expiresAt DateTime

  firstViewedAt    DateTime?
  lastDownloadedAt DateTime?
  reportPurgedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop, createdAt])
  @@index([shop, status])
  @@index([expiresAt])
}

// Audit trail for protected-data processing.
// Never store names, phones, emails or addresses in this table.
model ProtectedDataAccessLog {
  id           String  @id @default(cuid())
  shop         String
  action       String
  resourceType String
  resourceId   String?
  actorType    String  @default("SYSTEM")
  purpose      String

  createdAt DateTime @default(now())

  @@index([shop, createdAt])
  @@index([action, createdAt])
  @@index([resourceType, resourceId])
}
