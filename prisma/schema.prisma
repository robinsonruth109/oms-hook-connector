// prisma/schema.prisma
//
// Database schema for OMS Hook Connector.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shopify authentication sessions.
// Shopify's Prisma session-storage package depends on this model.
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

// Stores one OMS connection for each Shopify store.
model OmsConnection {
  id              String  @id @default(cuid())
  shop            String  @unique
  endpoint        String
  encryptedApiKey String
  isEnabled       Boolean @default(true)

  lastTestedAt      DateTime?
  lastTestSucceeded Boolean?
  lastTestMessage   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isEnabled])
}

// Records incoming Shopify webhook deliveries.
model WebhookEvent {
  id               String  @id @default(cuid())
  shop             String
  shopifyWebhookId String  @unique
  topic            String
  shopifyOrderId   String?
  status           String  @default("RECEIVED")
  errorMessage     String?

  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  orderPushJob OrderPushJob?

  @@index([shop, receivedAt])
  @@index([shop, status])
  @@index([shopifyOrderId])
}

// Stores a durable job for sending an order to the OMS.
model OrderPushJob {
  id             String       @id @default(cuid())
  shop           String
  webhookEventId String       @unique
  webhookEvent   WebhookEvent @relation(fields: [webhookEventId], references: [id], onDelete: Cascade)

  externalOrderId String
  invoiceId       String?

  // Retained temporarily for backward compatibility with old records.
  // New orders do not write the customer name into this field.
  customerName String?

  // Contains the complete OMS order encrypted with AES-256-GCM.
  // It becomes null after successful delivery or retention expiry.
  encryptedPayload String?

  // Personal order data is kept for at most seven days when delivery fails.
  personalDataExpiresAt DateTime?

  // Records when encrypted customer/order data was removed.
  payloadPurgedAt DateTime?

  status        String   @default("PENDING")
  attempts      Int      @default(0)
  maxAttempts   Int      @default(7)
  nextAttemptAt DateTime @default(now())
  lastError     String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  logs OrderPushLog[]

  @@index([shop, createdAt])
  @@index([shop, status])
  @@index([status, nextAttemptAt])
  @@index([externalOrderId])
  @@index([personalDataExpiresAt])
}

// Stores every delivery attempt without customer name, phone or address.
model OrderPushLog {
  id    String       @id @default(cuid())
  shop  String
  jobId String
  job   OrderPushJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  externalOrderId String
  invoiceId       String?
  status          String
  attemptNumber   Int
  httpStatus      Int?
  durationMs      Int?
  errorMessage    String?
  responseSummary String?

  createdAt DateTime @default(now())

  @@index([shop, createdAt])
  @@index([shop, status])
  @@index([jobId, attemptNumber])
  @@index([externalOrderId])
}

// Audit trail showing when the application processes protected data.
// This table must never contain names, phone numbers or addresses.
model ProtectedDataAccessLog {
  id           String  @id @default(cuid())
  shop         String
  action       String
  resourceType String
  resourceId   String?
  actorType    String  @default("SYSTEM")
  purpose      String

  createdAt DateTime @default(now())

  @@index([shop, createdAt])
  @@index([action, createdAt])
  @@index([resourceType, resourceId])
}
